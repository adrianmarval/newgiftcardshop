# Database Connection String (Use docker compose up -d)
DATABASE_URL="postgresql://username:password@localhost:5444/prismadb?schema=public"

#A secret value used for encryption and hashing. It must be at least 32 characters and generated with high entropy.
#You can also use openssl rand -base64 32 to generate one.
BETTER_AUTH_SECRET=

# Url base de la aplicacion
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app
